<html>
<head>
    <meta charset="UTF-8">
    <style>{{ main_style }}</style>
    <style>
        .logo {
            margin-top: 0.9rem;
        }
    </style>
</head>
<body>
<div id="main">
    <div class="main-border"></div>
    <img class="logo" src="https://moegirl.uk/images/9/9e/%E6%98%8E%E6%97%A5%E6%96%B9%E8%88%9F_LOGO.png"/>
    <div class="fortune-container">
        <div class="fortune-inner-box">
            <div class="title-container">
                {{ title }}
            </div>
            <div class="fortune-label">
                運&emsp;勢
            </div>
            <div class="content-container">
                {{ content }}
            </div>
        </div>
    </div>
    <img class="character" src="https://raw.githubusercontent.com/yuanyan3060/ArknightsGameResource/main/skin/{{ resource_key }}_1b.png" />
</div>
</body>
</html>
